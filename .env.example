# Get your Telegram bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────────
# MEERA'S OWN GOOGLE ACCOUNT (Gmail / Calendar / Meet / Tasks / Drive / Contacts)
# 1) In Google Cloud Console, ENABLE these APIs on the project that owns the OAuth client:
#       - Gmail API
#       - Google Calendar API
#       - Google Tasks API
#       - People API
#       - Google Drive API
#       - YouTube Data API v3   (already used for shorts)
# 2) Create OAuth 2.0 Client ID -> Application type: "Desktop app"
# 3) Put the client id/secret below, then run:  npm run auth:google
#    Sign in with the Google account you want Meera to OWN
#    (a real, separate Gmail account works best — that's "her" account).
# 4) The script will print the refresh token; paste it here.
# ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=meera.account@gmail.com
GOOGLE_USER_NAME=Meera
GOOGLE_USER_TIMEZONE=Asia/Kolkata

# Optional: YouTube Data API v3 (already supported for sharing shorts).
YOUTUBE_API_KEY=
